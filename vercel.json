{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/topics/([^/]+)/trainer", "dest": "/topics/$1/trainer.html" },
    { "src": "/topics/([^/]+)/theory", "dest": "/topics/$1/theory.html" },
    { "src": "/topics/([^/]+)/examples", "dest": "/topics/$1/examples.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
